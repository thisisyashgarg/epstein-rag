{
  "name": "epstein-rag-backend",
  "version": "1.0.0",
  "description": "Epstein RAG search backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "chroma": "../ingest/venv/bin/chroma run --path ../chroma_db --port 8001",
    "server": "SKIP_CHROMA=1 ts-node-dev --respawn --transpile-only src/index.ts",
    "ingest": "ts-node-dev --transpile-only src/ingest.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.15",
    "chromadb": "^3.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^4.47.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
